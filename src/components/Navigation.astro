---
export interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const locale = Astro.currentLocale || 'hr';
const prefix = locale === 'en' ? '/en' : '';

const normalize = (p: string) => (p.endsWith('/') ? p : p + '/');

const navigation = locale === 'en'
  ? [
      { name: 'Home',      href: `${prefix}/` },
      { name: 'Education', href: `${prefix}/education/` },
      { name: 'News',      href: `${prefix}/news/` },
      { name: 'Events',    href: `${prefix}/events/` },
      { name: 'Order',     href: `${prefix}/order/` },
    ]
  : [
      { name: 'Naslovnica', href: `${prefix}/` },
      { name: 'Edukacija',  href: `${prefix}/edukacija/` },
      { name: 'Novosti',    href: `${prefix}/novosti/` },
      { name: 'Događanja',  href: `${prefix}/dogadjanja/` },
      { name: 'Naruči',     href: `${prefix}/naruci/` },
    ];

// Language toggle: ručna mapping tablica za sve stranice
const pathMappings = {
  '/': '/en/',
  '/edukacija/': '/en/education/',
  '/dogadjanja/': '/en/events/',
  '/naruci/': '/en/order/',
  '/novosti/': '/en/news/',
  '/recenzije/': '/en/reviews/',
  '/o-prirucniku/': '/en/about-manual/',
  '/o-autorici/': '/en/about-author/',
  '/uvod/': '/en/introduction/',
  '/kontakt/': '/en/contact/',
  '/pozadine/': '/en/wallpapers/',
  '/en/': '/',
  '/en/news/': '/novosti/',
  '/en/education/': '/edukacija/',
  '/en/events/': '/dogadjanja/',
  '/en/order/': '/naruci/',
  '/en/reviews/': '/recenzije/',
  '/en/about-manual/': '/o-prirucniku/',
  '/en/about-author/': '/o-autorici/',
  '/en/introduction/': '/uvod/',
  '/en/contact/': '/kontakt/',
  '/en/wallpapers/': '/pozadine/',
};

const currentPathNormalized = normalize(currentPath);
const mappedPath = pathMappings[currentPathNormalized];

const switchToHR = locale === 'en' ? (mappedPath || '/') : currentPathNormalized;
const switchToEN = locale === 'hr' ? (mappedPath || '/en/') : currentPathNormalized;
---

<!-- Overlay — zatvara menu na tap izvan njega -->
<div id="nav-overlay" class="fixed inset-0 z-40 bg-black/20 hidden md:hidden" aria-hidden="true"></div>

<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-botanical-100 shadow-[0_1px_12px_0_rgba(0,0,0,0.06)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo — skraćen na mobile -->
      <a
        href={`${prefix}/`}
        class="flex-shrink-0 font-bold tracking-tight bg-gradient-to-r from-botanical-700 to-nature-600 bg-clip-text text-transparent hover:opacity-80 transition-opacity duration-200"
      >
        <span class="hidden sm:inline text-xl">{locale === 'en' ? 'Fragrant Signatures' : 'Mirisni potpisi'}</span>
        <span class="sm:hidden text-base">{locale === 'en' ? 'Fragrant Signatures' : 'Mirisni potpisi'}</span>
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-1">
        {navigation.map((item) => {
          const isActive = normalize(currentPath) === normalize(item.href);
          return (
            <a
              href={item.href}
              class={`relative px-4 py-2 text-sm font-medium uppercase tracking-wide transition-colors duration-200 rounded-lg
                ${isActive
                  ? 'text-botanical-700 bg-botanical-50'
                  : 'text-botanical-600 hover:text-botanical-800 hover:bg-botanical-50/70'
                }`}
            >
              {item.name}
              {isActive && (
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-botanical-500"></span>
              )}
            </a>
          );
        })}
      </div>

      <!-- Desna strana navbara -->
      <div class="flex items-center gap-2">

        <!-- Desktop: language pill -->
        <div class="hidden md:flex items-center bg-botanical-50 rounded-lg p-0.5 gap-0.5">
          <a href={switchToHR} class={`px-3 py-1 text-xs font-semibold rounded-md transition-all duration-200 ${locale === 'hr' ? 'bg-white text-botanical-700 shadow-sm' : 'text-botanical-400 hover:text-botanical-600'}`}>HR</a>
          <a href={switchToEN} class={`px-3 py-1 text-xs font-semibold rounded-md transition-all duration-200 ${locale === 'en' ? 'bg-white text-botanical-700 shadow-sm' : 'text-botanical-400 hover:text-botanical-600'}`}>EN</a>
        </div>

        <!-- Mobile: kompaktni language switcher uvijek vidljiv -->
        <div class="flex md:hidden items-center bg-botanical-50 rounded-lg p-0.5 gap-0.5">
          <a href={switchToHR} class={`px-2.5 py-1 text-xs font-semibold rounded-md transition-all duration-200 ${locale === 'hr' ? 'bg-white text-botanical-700 shadow-sm' : 'text-botanical-400'}`}>HR</a>
          <a href={switchToEN} class={`px-2.5 py-1 text-xs font-semibold rounded-md transition-all duration-200 ${locale === 'en' ? 'bg-white text-botanical-700 shadow-sm' : 'text-botanical-400'}`}>EN</a>
        </div>

        <!-- Hamburger -->
        <button
          type="button"
          id="hamburger-btn"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-botanical-600 hover:bg-botanical-50 focus:outline-none focus:ring-2 focus:ring-botanical-400 transition-colors duration-200"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Otvori izbornik"
        >
          <svg class="w-5 h-5 hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-5 h-5 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile menu dropdown -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-botanical-100 bg-white shadow-lg">
    <div class="px-3 py-3 space-y-0.5">
      {navigation.map((item) => {
        const isActive = normalize(currentPath) === normalize(item.href);
        return (
          <a
            href={item.href}
            class={`mobile-nav-link flex items-center gap-3 px-4 py-3.5 rounded-xl text-[15px] font-medium transition-colors duration-150 ${
              isActive
                ? 'bg-botanical-50 text-botanical-700 font-semibold'
                : 'text-botanical-700 active:bg-botanical-50'
            }`}
          >
            {isActive && <span class="w-1.5 h-1.5 rounded-full bg-botanical-500 flex-shrink-0"></span>}
            {!isActive && <span class="w-1.5 h-1.5 flex-shrink-0"></span>}
            {item.name}
          </a>
        );
      })}
    </div>
    <!-- Separator -->
    <div class="mx-4 h-px bg-botanical-100"></div>
    <div class="px-4 py-4 pb-6">
      <div class="flex items-center bg-botanical-50 rounded-xl p-1 gap-1">
        <a href={switchToHR} class={`flex-1 text-center py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 ${locale === 'hr' ? 'bg-white text-botanical-700 shadow-sm' : 'text-botanical-400'}`}>HR</a>
        <a href={switchToEN} class={`flex-1 text-center py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 ${locale === 'en' ? 'bg-white text-botanical-700 shadow-sm' : 'text-botanical-400'}`}>EN</a>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu') as HTMLElement | null;
    const overlay = document.getElementById('nav-overlay') as HTMLElement | null;
    const hamburger = document.querySelector('.hamburger-icon') as HTMLElement | null;
    const closeIcon = document.querySelector('.close-icon') as HTMLElement | null;
    if (!btn || !menu) return;

    function openMenu() {
      menu!.classList.remove('hidden');
      overlay?.classList.remove('hidden');
      hamburger?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      btn!.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu!.classList.add('hidden');
      overlay?.classList.add('hidden');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn!.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', () => {
      btn.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
    });

    // Zatvori na tap overlaya
    overlay?.addEventListener('click', closeMenu);

    // Zatvori kad se klikne nav link
    menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Zatvori na Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  });
</script>

<style>
  #mobile-menu:not(.hidden) {
    animation: slideDown 0.18s ease-out;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
