---
import background from '../assets/background.svg';
---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />
	<main>
		<section id="hero">
			<div class="logo">
				<h1 class="brand-title">Fragrant Signatures</h1>
				<p class="brand-subtitle">Manual for Creating Natural Perfumes</p>
			</div>
			
			<div class="hero-content">
				<h2>Discover the Art of Natural Perfumery</h2>
				<p class="hero-description">
					Embark on a journey through the world of botanical fragrances with Slobodanka's 
					meticulously crafted guide to creating bespoke natural perfumes.
				</p>
				
				<section id="links">
					<a class="button primary" href="/uvod">Počni čitati</a>
					<a class="button secondary" href="/o-prirucniku">O priručniku</a>
				</section>
			</div>
		</section>
	</main>

	<div id="features" class="features-box">
		<div class="feature-icon">
			<svg width="32" height="32" fill="none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
				<path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
				<path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
				<path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
			</svg>
		</div>
		<h3>Comprehensive Guide</h3>
		<p>
			From theoretical foundations to practical techniques, learn everything about natural 
			perfumery with expert guidance and inspiring examples.
		</p>
	</div>
</div>

<style>
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
		opacity: 0.3;
	}

	#container {
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		height: 100vh;
		display: flex;
		flex-direction: column;
	}

	main {
		flex: 1;
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 2rem;
	}

	#hero {
		text-align: center;
		max-width: 800px;
	}

	.logo {
		margin-bottom: 3rem;
	}

	.brand-title {
		font-size: 3.5rem;
		font-weight: 700;
		background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 50%, #F59E0B 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin: 0 0 0.5rem 0;
		letter-spacing: -0.02em;
	}

	.brand-subtitle {
		font-size: 1.25rem;
		color: #6B7280;
		margin: 0;
		font-weight: 400;
	}

	.hero-content h2 {
		font-size: 2rem;
		font-weight: 600;
		color: #1F2937;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
	}

	.hero-description {
		font-size: 1.125rem;
		color: #4B5563;
		line-height: 1.7;
		margin: 0 0 2.5rem 0;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	#links {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.button {
		display: inline-flex;
		align-items: center;
		padding: 0.875rem 2rem;
		border-radius: 0.75rem;
		text-decoration: none;
		font-weight: 600;
		font-size: 1rem;
		transition: all 0.2s ease;
		border: 2px solid transparent;
	}

	.button.primary {
		background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%);
		color: white;
		box-shadow: 0 4px 14px 0 rgba(139, 92, 246, 0.3);
	}

	.button.primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 25px 0 rgba(139, 92, 246, 0.4);
	}

	.button.secondary {
		background: rgba(255, 255, 255, 0.8);
		color: #374151;
		border-color: #E5E7EB;
		backdrop-filter: blur(10px);
	}

	.button.secondary:hover {
		background: rgba(255, 255, 255, 0.95);
		border-color: #D1D5DB;
		transform: translateY(-1px);
	}

	.features-box {
		position: absolute;
		bottom: 2rem;
		right: 2rem;
		max-width: 320px;
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.9);
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(20px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
	}

	.feature-icon {
		width: 3rem;
		height: 3rem;
		background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%);
		border-radius: 0.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 1rem;
		color: white;
	}

	.features-box h3 {
		font-size: 1.25rem;
		font-weight: 600;
		color: #1F2937;
		margin: 0 0 0.75rem 0;
	}

	.features-box p {
		color: #6B7280;
		font-size: 0.875rem;
		line-height: 1.6;
		margin: 0;
	}

	@media screen and (max-width: 768px) {
		.brand-title {
			font-size: 2.5rem;
		}

		.hero-content h2 {
			font-size: 1.5rem;
		}

		.hero-description {
			font-size: 1rem;
		}

		#links {
			flex-direction: column;
			align-items: center;
		}

		.button {
			width: 100%;
			max-width: 280px;
			justify-content: center;
		}

		.features-box {
			position: static;
			margin: 2rem 1rem;
			max-width: none;
		}
	}

	@media screen and (max-height: 600px) {
		.features-box {
			display: none;
		}
	}
</style>
