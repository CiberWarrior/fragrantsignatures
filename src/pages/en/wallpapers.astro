---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Wallpapers - Fragrant Signatures"
  description="Download free wallpapers for desktop and mobile devices with botanical motifs from Fragrant Signatures"
  currentPath="/en/wallpapers"
  lang="en"
>
  <div class="min-h-screen bg-gradient-to-br from-botanical-50 via-white to-nature-50">
    <div class="container mx-auto px-4 py-16 max-w-6xl">
      <!-- Hero Section -->
      <div class="text-center mb-16">
        <h1 class="text-5xl bg-gradient-to-r from-botanical-600 to-nature-500 bg-clip-text text-transparent mb-6">
          Wallpapers
        </h1>
        <p class="text-xl text-botanical-600 max-w-3xl mx-auto leading-relaxed">
          Download free wallpapers for desktop and mobile devices with botanical motifs
        </p>
      </div>

      <!-- Main Content -->
      <div class="space-y-12">
        <!-- Desktop Wallpapers -->
        <div class="bg-white/80 backdrop-blur-sm rounded-3xl p-8 md:p-12 shadow-xl border border-botanical-100">
          <h2 class="text-3xl text-botanical-800 mb-8 text-center">Desktop Wallpapers (1920x1080)</h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Fragrant Signatures Desktop -->
            <div class="bg-gradient-to-br from-botanical-50 to-nature-50 rounded-2xl p-6 text-center">
              <div class="mb-4">
                <img 
                  src="/images/FS_desktop_wallpaper_1920x1080-scaled.jpg" 
                  alt="Fragrant Signatures Desktop Wallpaper"
                  class="w-full h-32 object-cover rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300"
                />
              </div>
              <h3 class="text-lg text-botanical-800 mb-2">Fragrant Signatures</h3>
              <p class="text-sm text-ink-600 mb-4">Classic design with natural elements</p>
              <a 
                href="/images/FS_desktop_wallpaper_1920x1080-scaled.jpg" 
                download="Fragrant_Signatures_Desktop_Wallpaper.jpg"
                class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-botanical-600 to-botanical-700 text-white rounded-lg hover:from-botanical-700 hover:to-botanical-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl font-medium"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Download
              </a>
            </div>

            <!-- Mirisni Potpisi Desktop -->
            <div class="bg-gradient-to-br from-botanical-50 to-nature-50 rounded-2xl p-6 text-center">
              <div class="mb-4">
                <img 
                  src="/images/MP_desktop_wallpaper_1920x1080-scaled.jpg" 
                  alt="Mirisni Potpisi Desktop Wallpaper"
                  class="w-full h-32 object-cover rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300"
                />
              </div>
              <h3 class="text-lg text-botanical-800 mb-2">Mirisni Potpisi</h3>
              <p class="text-sm text-ink-600 mb-4">Croatian version with natural motifs</p>
              <a 
                href="/images/MP_desktop_wallpaper_1920x1080-scaled.jpg" 
                download="Mirisni_Potpisi_Desktop_Wallpaper.jpg"
                class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-botanical-600 to-botanical-700 text-white rounded-lg hover:from-botanical-700 hover:to-botanical-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl font-medium"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Download
              </a>
            </div>

            <!-- Nature Wallpaper 1 -->
            <div class="bg-gradient-to-br from-botanical-50 to-nature-50 rounded-2xl p-6 text-center">
              <div class="mb-4">
                <img 
                  src="/images/botanica_wallpaper.png" 
                  alt="Nature Wallpaper 1"
                  class="w-full h-32 object-cover rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300"
                />
              </div>
              <h3 class="text-lg text-botanical-800 mb-2">Nature 1</h3>
              <p class="text-sm text-ink-600 mb-4">Minimalist natural design</p>
              <a 
                href="/images/botanica_wallpaper.png" 
                download="Nature_Wallpaper_1.png"
                class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-botanical-600 to-botanical-700 text-white rounded-lg hover:from-botanical-700 hover:to-botanical-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl font-medium"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Download
              </a>
            </div>
          </div>
        </div>

        <!-- Mobile Wallpapers -->
        <div class="bg-white/80 backdrop-blur-sm rounded-3xl p-8 md:p-12 shadow-xl border border-botanical-100">
          <h2 class="text-3xl text-botanical-800 mb-8 text-center">Mobile Wallpapers (640x960)</h2>
          
          <div class="grid md:grid-cols-2 gap-8">
            <!-- Fragrant Signatures Mobile -->
            <div class="bg-gradient-to-br from-botanical-50 to-nature-50 rounded-2xl p-6 text-center">
              <div class="mb-4">
                <img 
                  src="/images/FS_mobile_wallpaper_640x960.jpg" 
                  alt="Fragrant Signatures Mobile Wallpaper"
                  class="w-32 h-48 object-cover rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 mx-auto"
                />
              </div>
              <h3 class="text-lg text-botanical-800 mb-2">Fragrant Signatures Mobile</h3>
              <p class="text-sm text-ink-600 mb-4">Optimized for mobile devices</p>
              <a 
                href="/images/FS_mobile_wallpaper_640x960.jpg" 
                download="Fragrant_Signatures_Mobile_Wallpaper.jpg"
                class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-nature-600 to-nature-700 text-white rounded-lg hover:from-nature-700 hover:to-nature-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl font-medium"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Download
              </a>
            </div>

            <!-- Nature Wallpaper 2 -->
            <div class="bg-gradient-to-br from-botanical-50 to-nature-50 rounded-2xl p-6 text-center">
              <div class="mb-4">
                <img 
                  src="/images/botanica_wallpaper_2.png" 
                  alt="Nature Wallpaper 2"
                  class="w-32 h-48 object-cover rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 mx-auto"
                />
              </div>
              <h3 class="text-lg text-botanical-800 mb-2">Nature 2</h3>
              <p class="text-sm text-ink-600 mb-4">Stylized natural design</p>
              <a 
                href="/images/botanica_wallpaper_2.png" 
                download="Nature_Wallpaper_2.png"
                class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-nature-600 to-nature-700 text-white rounded-lg hover:from-nature-700 hover:to-nature-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl font-medium"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Download
              </a>
            </div>
          </div>
        </div>

        <!-- Additional Nature Wallpapers -->
        <div class="bg-white/80 backdrop-blur-sm rounded-3xl p-8 md:p-12 shadow-xl border border-botanical-100">
          <h2 class="text-3xl text-botanical-800 mb-8 text-center">Additional Nature Design</h2>
          
          <div class="grid md:grid-cols-2 gap-8">
            <!-- Nature Wallpaper 3 -->
            <div class="bg-gradient-to-br from-botanical-50 to-nature-50 rounded-2xl p-6 text-center">
              <div class="mb-4">
                <img 
                  src="/images/botanica_wallpaper_3.png" 
                  alt="Nature Wallpaper 3"
                  class="w-full h-32 object-cover rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300"
                />
              </div>
              <h3 class="text-lg text-botanical-800 mb-2">Nature 3</h3>
              <p class="text-sm text-ink-600 mb-4">Rich botanical arrangement</p>
              <a 
                href="/images/botanica_wallpaper_3.png" 
                download="Nature_Wallpaper_3.png"
                class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-accent-600 to-accent-700 text-white rounded-lg hover:from-accent-700 hover:to-accent-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl font-medium"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Download
              </a>
            </div>

            <!-- Info Card -->
            <div class="bg-gradient-to-br from-nature-50 to-botanical-50 rounded-2xl p-6 text-center">
              <div class="w-16 h-16 bg-gradient-to-br from-botanical-100 to-nature-100 rounded-2xl flex items-center justify-center mb-4 mx-auto">
                <svg class="w-8 h-8 text-botanical-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-lg text-botanical-800 mb-2">How to Use</h3>
              <p class="text-sm text-ink-600 mb-4">
                Click the "Download" button for direct download. Wallpapers are optimized for different devices and resolutions.
              </p>
              <p class="text-xs text-ink-500">
                All wallpapers are free for personal use.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <div class="mt-16 flex justify-center">
        <a 
          href="/en/" 
          class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-nature-600 to-nature-700 text-white rounded-xl hover:from-nature-700 hover:to-nature-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl font-medium"
        >
          ← Home
        </a>
      </div>
    </div>
  </div>
</Layout>
