---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Order Fragrant Signatures Manual | Fragrant Signatures"
  description="Order the manual for creating natural perfumes. Price 55,00 EUR with delivery within Croatia. Contact us by phone or email."
  currentPath="/en/order"
  lang="en"
>
  <div class="min-h-screen bg-gradient-to-br from-botanical-50 via-white to-nature-50">
    <div class="container mx-auto px-4 py-16 max-w-6xl">

      <!-- Hero Section -->
      <div class="text-center mb-16">
        <div class="mb-8">
          <img
            src="/images/fw-logo-red.png"
            alt="Fragrant Signatures Logo"
            class="mx-auto max-w-md h-auto"
          />
        </div>

        <div class="flex items-center justify-center mb-8">
          <div class="flex-1 h-px bg-gradient-to-r from-transparent via-botanical-300 to-transparent"></div>
          <div class="mx-4 w-2 h-2 bg-botanical-500 rounded-full"></div>
          <div class="flex-1 h-px bg-gradient-to-r from-transparent via-botanical-300 to-transparent"></div>
        </div>

        <h1 class="text-5xl font-bold text-botanical-800 mb-8">Order</h1>
      </div>

      <!-- Contact card -->
      <div class="w-full max-w-xl mx-auto bg-white/80 backdrop-blur-sm rounded-2xl p-8 shadow-xl border border-botanical-200">
        <h2 class="text-2xl font-bold text-botanical-800 mb-3">Contact us</h2>

        <div class="space-y-4">
          <!-- Phone -->
          <a
            href="tel:+385917886783"
            class="flex items-center gap-4 p-5 rounded-xl border border-botanical-200 hover:bg-botanical-50 transition-colors duration-200 group"
          >
            <div class="w-12 h-12 bg-gradient-to-br from-nature-100 to-botanical-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-nature-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-medium text-botanical-400 uppercase tracking-wider mb-1">Phone</p>
              <p class="text-lg font-bold text-botanical-800 group-hover:text-botanical-600 transition-colors">+385 91 788 6783</p>
            </div>
          </a>

          <!-- E-mail -->
          <a
            href="mailto:slo.postic@gmail.com"
            class="flex items-center gap-4 p-5 rounded-xl border border-botanical-200 hover:bg-botanical-50 transition-colors duration-200 group"
          >
            <div class="w-12 h-12 bg-gradient-to-br from-botanical-100 to-accent-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-botanical-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-medium text-botanical-400 uppercase tracking-wider mb-1">E-mail</p>
              <p class="text-lg font-bold text-botanical-800 group-hover:text-botanical-600 transition-colors">slo.postic@gmail.com</p>
            </div>
          </a>
        </div>

        <div class="mt-8 pt-6 border-t border-botanical-100">
          <p class="text-sm text-botanical-500 text-center">
            Manual price: <strong class="text-botanical-700">55,00 €</strong> — includes delivery within Croatia
          </p>
        </div>
      </div>

    </div>
  </div>
</Layout>
