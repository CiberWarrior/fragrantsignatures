---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Kontakt - Fragrant Signatures" 
  description="Kontaktirajte nas za pitanja o Fragrant Signatures, prirodnoj parfumeriji ili za naručivanje."
  currentPath="/kontakt"
>
  <div class="min-h-screen bg-gradient-to-br from-lavender-50 via-white to-perfume-50">
    <div class="container mx-auto px-4 py-16 max-w-6xl">
      <!-- Hero Section -->
      <div class="text-center mb-16">
        <h1 class="text-5xl font-bold bg-gradient-to-r from-perfume-600 to-rose-500 bg-clip-text text-transparent mb-6">
          Kontakt
        </h1>
        <p class="text-xl text-lavender-600 max-w-3xl mx-auto leading-relaxed">
          Kontaktirajte nas za pitanja o Fragrant Signatures ili prirodnoj parfumeriji
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-8 shadow-xl border border-lavender-200">
          <h2 class="text-2xl font-bold text-lavender-800 mb-6">Send us a Message</h2>
          
          <form class="space-y-6" id="contact-form">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="firstName" class="block text-sm font-medium text-lavender-700 mb-2">
                  First Name *
                </label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  required
                  class="w-full px-4 py-3 border border-lavender-300 rounded-lg focus:ring-2 focus:ring-perfume-500 focus:border-perfume-500 transition-all duration-300 bg-white/70 backdrop-blur-sm"
                  placeholder="Your first name"
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-lavender-700 mb-2">
                  Last Name *
                </label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  required
                  class="w-full px-4 py-3 border border-lavender-300 rounded-lg focus:ring-2 focus:ring-perfume-500 focus:border-perfume-500 transition-all duration-300 bg-white/70 backdrop-blur-sm"
                  placeholder="Your last name"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-lavender-700 mb-2">
                Email Address *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-lavender-300 rounded-lg focus:ring-2 focus:ring-perfume-500 focus:border-perfume-500 transition-all duration-300 bg-white/70 backdrop-blur-sm"
                placeholder="your.email@example.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-lavender-700 mb-2">
                Subject *
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full px-4 py-3 border border-lavender-300 rounded-lg focus:ring-2 focus:ring-perfume-500 focus:border-perfume-500 transition-all duration-300 bg-white/70 backdrop-blur-sm"
              >
                <option value="">Select a subject</option>
                <option value="general">General Inquiry</option>
                <option value="order">Order Information</option>
                <option value="book">About the Book</option>
                <option value="workshop">Workshop/Education</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-lavender-700 mb-2">
                Message *
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full px-4 py-3 border border-lavender-300 rounded-lg focus:ring-2 focus:ring-perfume-500 focus:border-perfume-500 transition-all duration-300 bg-white/70 backdrop-blur-sm resize-none"
                placeholder="Tell us how we can help you..."
              ></textarea>
            </div>

            <div class="flex items-center">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="h-4 w-4 text-perfume-600 focus:ring-perfume-500 border-lavender-300 rounded"
              />
              <label for="privacy" class="ml-2 block text-sm text-lavender-700">
                I agree to the <a href="#" class="text-perfume-600 hover:text-perfume-700 underline">Privacy Policy</a> *
              </label>
            </div>

            <button
              type="submit"
              class="w-full bg-gradient-to-r from-perfume-600 to-rose-500 text-white py-4 px-6 rounded-lg font-semibold hover:from-perfume-700 hover:to-rose-600 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Information -->
        <div class="space-y-8">
          <!-- Contact Details -->
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-8 shadow-xl border border-lavender-200">
            <h2 class="text-2xl font-bold text-lavender-800 mb-6">Get in Touch</h2>
            
            <div class="space-y-6">
              <div class="flex items-start space-x-4">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-gradient-to-br from-perfume-100 to-rose-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-perfume-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h3 class="font-semibold text-lavender-800">Email</h3>
                  <p class="text-lavender-600">info@fragrant-signatures.eu</p>
                </div>
              </div>

              <div class="flex items-start space-x-4">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-gradient-to-br from-perfume-100 to-rose-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-perfume-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h3 class="font-semibold text-lavender-800">Location</h3>
                  <p class="text-lavender-600">Croatia</p>
                </div>
              </div>

              <div class="flex items-start space-x-4">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-gradient-to-br from-perfume-100 to-rose-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-perfume-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h3 class="font-semibold text-lavender-800">Response Time</h3>
                  <p class="text-lavender-600">Within 24-48 hours</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-8 shadow-xl border border-lavender-200">
            <h2 class="text-2xl font-bold text-lavender-800 mb-6">Follow Us</h2>
            <div class="flex space-x-4">
              <a href="#" class="w-12 h-12 bg-gradient-to-br from-perfume-100 to-rose-100 rounded-lg flex items-center justify-center hover:from-perfume-200 hover:to-rose-200 transition-all duration-300 transform hover:scale-110">
                <svg class="w-6 h-6 text-perfume-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
                </svg>
              </a>
              <a href="#" class="w-12 h-12 bg-gradient-to-br from-perfume-100 to-rose-100 rounded-lg flex items-center justify-center hover:from-perfume-200 hover:to-rose-200 transition-all duration-300 transform hover:scale-110">
                <svg class="w-6 h-6 text-perfume-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/>
                </svg>
              </a>
              <a href="#" class="w-12 h-12 bg-gradient-to-br from-perfume-100 to-rose-100 rounded-lg flex items-center justify-center hover:from-perfume-200 hover:to-rose-200 transition-all duration-300 transform hover:scale-110">
                <svg class="w-6 h-6 text-perfume-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.746-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001.012.001z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <div class="mt-16 flex justify-center space-x-4">
        <a 
          href="/recenzije" 
          class="inline-flex items-center px-6 py-3 bg-lavender-600 text-white rounded-lg hover:bg-lavender-700 transition-all duration-300 transform hover:scale-105 font-medium"
        >
          ← Recenzije
        </a>
        <a 
          href="/naruci" 
          class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-perfume-600 to-rose-500 text-white rounded-lg hover:from-perfume-700 hover:to-rose-600 transition-all duration-300 transform hover:scale-105 font-medium"
        >
          Naruči knjigu →
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Contact form handling
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form');
    
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Get form data
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        // Simple validation
        if (!data.firstName || !data.lastName || !data.email || !data.subject || !data.message) {
          alert('Please fill in all required fields.');
          return;
        }
        
        // Simulate form submission
        const submitButton = form.querySelector('button[type="submit"]');
        const originalText = submitButton.textContent;
        
        submitButton.textContent = 'Sending...';
        submitButton.disabled = true;
        
        // Simulate API call
        setTimeout(() => {
          alert('Thank you for your message! We will get back to you within 24-48 hours.');
          form.reset();
          submitButton.textContent = originalText;
          submitButton.disabled = false;
        }, 2000);
      });
    }
  });
</script>
