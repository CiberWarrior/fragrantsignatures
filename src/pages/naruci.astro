---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Naruči priručnik Mirisni potpisi | ETSY ili kontakt forma | Fragrant Signatures" 
  description="Naručite priručnik za kreiranje prirodnih parfema putem ETSY trgovine ili kontakt forme. Cijena 55,00 eura s dostavom unutar Hrvatske. Dostupno odmah."
  currentPath="/naruci"
>
  <div class="min-h-screen bg-gradient-to-br from-botanical-50 via-white to-nature-50">
    <div class="container mx-auto px-4 py-16 max-w-6xl">
      <!-- Hero Section -->
      <div class="text-center mb-16">
        <div class="mb-8">
          <img 
            src="/images/fw-logo-red.png" 
            alt="Fragrant Signatures Logo"
            class="mx-auto max-w-md h-auto"
          />
        </div>
        
        <!-- Stylized Divider -->
        <div class="flex items-center justify-center mb-8">
          <div class="flex-1 h-px bg-gradient-to-r from-transparent via-botanical-300 to-transparent"></div>
          <div class="mx-4 w-2 h-2 bg-botanical-500 rounded-full"></div>
          <div class="flex-1 h-px bg-gradient-to-r from-transparent via-botanical-300 to-transparent"></div>
        </div>
        
        <h1 class="text-5xl font-bold text-botanical-800 mb-8">
          Naruči
        </h1>
      </div>

      <!-- Poruka nakon uspješnog slanja -->
      {Astro.url.searchParams.get('poslano') !== null && (
        <div class="max-w-xl mx-auto mb-6 p-4 bg-botanical-100 border border-botanical-300 rounded-lg text-botanical-800 text-center">
          Hvala! Vaša poruka je poslana. Javit ćemo vam se uskoro.
        </div>
      )}

      <!-- Kontaktni obrazac (FormSubmit.co → slo.postic@gmail.com, klijent aktivira 1x) -->
      <div class="w-full max-w-xl mx-auto bg-white/80 backdrop-blur-sm rounded-2xl p-8 shadow-xl border border-botanical-200">
        <h2 class="text-2xl font-bold text-botanical-800 mb-6">Kontaktirajte nas</h2>

        <form
          action="https://formsubmit.co/slo.postic@gmail.com"
          method="POST"
          class="space-y-6"
        >
          <input type="hidden" name="_next" value="https://fragrant-signatures.eu/naruci/?poslano=1" />
          <input type="hidden" name="_subject" value="Nova poruka - Naruči stranica" />
          <input type="text" name="_honey" style="display: none" tabindex="-1" autocomplete="off" />

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="ime" class="block text-sm font-medium text-botanical-700 mb-2">
                Ime *
              </label>
              <input
                type="text"
                id="ime"
                name="ime"
                required
                class="w-full px-4 py-3 border border-botanical-300 rounded-lg focus:ring-2 focus:ring-botanical-500 focus:border-botanical-500 transition-all duration-300 bg-white"
                placeholder="Vaše ime"
              />
            </div>
            <div>
              <label for="prezime" class="block text-sm font-medium text-botanical-700 mb-2">
                Prezime *
              </label>
              <input
                type="text"
                id="prezime"
                name="prezime"
                required
                class="w-full px-4 py-3 border border-botanical-300 rounded-lg focus:ring-2 focus:ring-botanical-500 focus:border-botanical-500 transition-all duration-300 bg-white"
                placeholder="Vaše prezime"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-botanical-700 mb-2">
              E-mail *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-botanical-300 rounded-lg focus:ring-2 focus:ring-botanical-500 focus:border-botanical-500 transition-all duration-300 bg-white"
              placeholder="vas@email.com"
            />
          </div>

          <div>
            <label for="poruka" class="block text-sm font-medium text-botanical-700 mb-2">
              Poruka *
            </label>
            <textarea
              id="poruka"
              name="poruka"
              rows="6"
              required
              class="w-full px-4 py-3 border border-botanical-300 rounded-lg focus:ring-2 focus:ring-botanical-500 focus:border-botanical-500 transition-all duration-300 bg-white resize-none"
              placeholder="Vaša poruka..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-nature-600 to-nature-700 text-white py-4 px-6 rounded-lg font-semibold hover:from-nature-700 hover:to-nature-600 transition-all duration-300 transform hover:scale-[1.02] shadow-lg hover:shadow-xl"
          >
            Pošalji poruku
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
