---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Naruči priručnik Mirisni potpisi | ETSY ili kontakt forma | Fragrant Signatures" 
  description="Naručite priručnik za kreiranje prirodnih parfema putem ETSY trgovine ili kontakt forme. Cijena €62,73 s dostavom unutar Hrvatske. Dostupno odmah."
  currentPath="/naruci"
>
  <div class="min-h-screen bg-gradient-to-br from-botanical-50 via-white to-nature-50">
    <div class="container mx-auto px-4 py-16 max-w-6xl">
      <!-- Hero Section -->
      <div class="text-center mb-16">
        <div class="mb-8">
          <img 
            src="/images/fw-logo-red.png" 
            alt="Fragrant Signatures Logo"
            class="mx-auto max-w-md h-auto"
          />
        </div>
        
        <!-- Stylized Divider -->
        <div class="flex items-center justify-center mb-8">
          <div class="flex-1 h-px bg-gradient-to-r from-transparent via-botanical-300 to-transparent"></div>
          <div class="mx-4 w-2 h-2 bg-botanical-500 rounded-full"></div>
          <div class="flex-1 h-px bg-gradient-to-r from-transparent via-botanical-300 to-transparent"></div>
        </div>
        
        <h1 class="text-5xl font-bold text-botanical-800 mb-8">
          Naruči
        </h1>
        <p class="text-xl text-botanical-700 max-w-3xl mx-auto leading-relaxed">
          Možete naručiti Mirisne potpise iz naše <a href="https://www.etsy.com/shop/FierceWomenArt?ref=simple-shop-header-name&listing_id=1244543801" target="_blank" rel="noopener noreferrer" class="text-botanical-600 hover:text-botanical-800 underline font-medium transition-colors duration-300">ETSY trgovine</a>, ili nas kontaktirajte putem ove forme:
        </p>
      </div>

      <!-- Google Form -->
      <div class="w-full max-w-4xl mx-auto">
        <iframe 
          src="https://docs.google.com/forms/d/e/1FAIpQLSdGlY6I_5bFYAkx-bc1gOgYLaXSpiaO0yxIaA5bjBruHY2_KQ/viewform?embedded=true" 
          width="100%" 
          height="2027" 
          frameborder="0" 
          marginheight="0" 
          marginwidth="0"
          class="rounded-lg"
        >
          Loading…
        </iframe>
      </div>
      
      <!-- Navigation -->
      <div class="mt-16 flex justify-center">
        <a 
          href="/" 
          class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-nature-600 to-nature-700 text-white rounded-xl hover:from-nature-700 hover:to-nature-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl font-medium"
        >
          ← Početna
        </a>
      </div>
    </div>
  </div>
</Layout>
